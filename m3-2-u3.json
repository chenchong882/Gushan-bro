                "tips": [
                    {
                        "label": "詢問人物身分",
                        "text": "Who's he / she?"
                    },
                    {
                        "label": "介紹人物身分",
                        "text": "He's / She's my + 家庭成員 (father, mother, brother, etc.)."
                    },
                    {
                        "label": "描述人物外貌",
                        "text": "He's / She's + 形容詞 (tall, short)."
                    }
                ],
                "notes": [
                    {
                        "title": "主題一：詢問與介紹人物身分",
                        "rule": "使用疑問詞 Who (誰) 搭配 be 動詞 (is) 來詢問第三人稱單數的身分。回答時，使用所有格 my (我的) 加上家庭成員稱謂。",
                        "description": "當想知道某位男士或女士是誰時，可以使用這個句型。注意男女代名詞 (he / she) 的對應。",
                        "examples": [
                            "Who's he? He is my grandfather. (他是誰？他是我的爺爺。)",
                            "Who's she? She is my sister. (她是誰？她是我的姐姐/妹妹。)"
                        ]
                    },
                    {
                        "title": "主題二：描述人物外貌特徵",
                        "rule": "主詞 (He / She / 家庭成員) + be 動詞 (is) + 形容詞 (tall / short).",
                        "description": "用來描述一個人的外貌特徵。此課著重於高 (tall) 與矮 (short) 的基本表達。",
                        "examples": [
                            "My brother is tall. (我的哥哥/弟弟很高。)",
                            "She's short. (她很矮。)"
                        ]
                    },
                    {
                        "title": "主題三：代名詞與 be 動詞的縮寫規則 (Contractions)",
                        "rule": "在口語對話中，常將 who, he, she 與 is 進行縮寫，使用撇號 (') 來替代省略的字母 i。",
                        "description": "who is 縮寫為 who's；he is 縮寫為 he's；she is 縮寫為 she's。",
                        "examples": [
                            "Who's she? She's my grandmother. (她是誰？她是我的奶奶。)"
                        ]
                    }
                ],
