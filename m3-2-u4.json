            "grammar": {
                "tips": [
                    {
                        "label": "基本句型",
                        "text": "問句：Are you a + [職業]? / Is he (she) a + [職業]?\n答句：Yes, I am. / No, I'm not. 或 Yes, he (she) is. / No, he (she) isn't."
                    }
                ],
                "notes": [
                    {
                        "title": "Be 動詞與人稱的搭配",
                        "rule": "在疑問句中，Be 動詞需移至句首並大寫。第一人稱複數/第二人稱使用 Are，第三人稱單數使用 Is。",
                        "description": "這是 Yes/No 疑問句的核心規則，決定了句首要用哪一個 Be 動詞。",
                        "examples": [
                            "Are you a student? (你是一位學生嗎？)",
                            "Is she a nurse? (她是一位護理師嗎？)"
                        ]
                    },
                    {
                        "title": "不定冠詞 a/an 的使用",
                        "rule": "當職業名詞為可數單數時，前方必須加上 a (子音開頭) 或 an (母音開頭)。",
                        "description": "職業名詞前必須要有冠詞來修飾身分。",
                        "examples": [
                            "He is a cook. (他是一位廚師。)"
                        ]
                    },
                    {
                        "title": "簡答原則",
                        "rule": "簡答時，Yes 後面的代名詞與 Be 動詞不可縮寫；No 後面則通常使用縮寫以符合日常口語。",
                        "description": "注意肯定與否定簡答的縮寫限制，這是常見考點。",
                        "examples": [
                            "Yes, I am. (不可寫成 Yes, I'm.)",
                            "No, he's not. / No, he isn't."
                        ]
                    }
                ],
